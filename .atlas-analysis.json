  "keyFeatures": [
    "Visual workflow canvas for composing multi-step modeling pipelines",
    "AI-assisted model creation from equations, documents, and images",
    "Scientific simulation via CIEMSS (calibrate, simulate, optimize, ensemble)",
    "MIRA-based model stratification and transformation",
    "Knowledge extraction from PDFs, papers, and scientific literature",
    "Interactive Beaker notebook environment for code-based analysis",
    "Project-based asset management for models, datasets, and documents",
    "Role-based access control via Keycloak",
    "FUNMAN for model validation and feasibility analysis"
  ],
  "publicApiSurface": [
    "GET/POST/PUT/DELETE /models",
    "GET/POST/PUT/DELETE /projects",
    "GET/POST/PUT/DELETE /datasets",
    "GET/POST/PUT/DELETE /workflows",
    "POST /simulations (simulate, calibrate, optimize, ensemble)",
    "POST /gollm/* (AI model enrichment, configuration, equation extraction)",
    "POST /mira/* (model stratification, SBML/STELLA/MDL conversion)",
    "GET/POST /documents",
    "POST /funman (model validation)",
    "GET /knowledge (DKG knowledge graph queries)"
  ]
